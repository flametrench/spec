      "input": {
        "stored_sign_count": 10,
        "authenticator_data_hex": "ab19f54596275ecbc737f2bd9a005db9c9c2494d9cb68b0bdd30d20c99e09499050000000a",
        "signature_hex": "304502210087d550079529cc6895b42dc09028ab55dd0f1e4add5c6c55bdcf35e8675a4b270220270e489187207c176db87015f748c74f40749a444a7bf1a6877093023503299f"
      },
      "expected": {
        "result": {
          "ok": false,
          "reason": "counter_regression"
        }
      }
    },
    {
      "id": "webauthn.counter.lesser_rejected",
      "description": "Stored=10, incoming=7. A counter that decreases is the clearest cloned-authenticator signal.",
      "input": {
        "stored_sign_count": 10,
        "authenticator_data_hex": "ab19f54596275ecbc737f2bd9a005db9c9c2494d9cb68b0bdd30d20c99e094990500000007",
        "signature_hex": "304502200827e7a710bbdb25f22e237341cba971cec6df91a2257509f22313f5c4a3de15022100e7b7d6ca1bb277d48ff52139e2c79c32cb8580cce776b9da6158ecd603e178d7"
      },
      "expected": {
        "result": {
          "ok": false,
          "reason": "counter_regression"
        }
      }
    },
    {
      "id": "webauthn.counter.greater_accepted",
      "description": "Stored=10, incoming=11. A strictly-greater counter is the normal path; verifier returns the new sign count.",
      "input": {
        "stored_sign_count": 10,
        "authenticator_data_hex": "ab19f54596275ecbc737f2bd9a005db9c9c2494d9cb68b0bdd30d20c99e09499050000000b",
        "signature_hex": "3045022100b52f0995aab52ebf315f1b0e03b3dadc8a2df2d72451a4216d8076b44ace2597022046b7d878cbb758928eb4786a7b28e547bc17955041f0c4be3403914eabe524e6"
