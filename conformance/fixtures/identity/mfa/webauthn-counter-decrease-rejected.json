  "spec_section": "decisions/0008-mfa.md",
  "description": "WebAuthn signature-counter monotonicity per spec \u00a76.1.1. A counter that fails to strictly advance \u2014 when at least one of stored/incoming is non-zero \u2014 is the cloned-authenticator signal and MUST be rejected. The both-zero case is permitted (some authenticators do not track a counter).",
  "shared": {
    "cose_public_key_hex": "a501020326200121582060fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb62258207903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299",
    "stored_rp_id": "flametrench.test",
    "expected_origin": "https://flametrench.test",
    "expected_challenge_hex": "666c616d657472656e63682d776562617574686e2d6368616c6c656e67652d76302e32",
    "client_data_json_hex": "7b226368616c6c656e6765223a225a6d786862575630636d567559326774643256695958563061473474593268686247786c626d646c4c5859774c6a49222c226f726967696e223a2268747470733a2f2f666c616d657472656e63682e74657374222c2274797065223a22776562617574686e2e676574227d"
  },
  "tests": [
    {
      "id": "webauthn.counter.equal_rejected",
