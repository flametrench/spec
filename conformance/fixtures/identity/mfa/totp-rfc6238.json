    },
    {
      "id": "totp.sha512.t-1234567890",
      "description": "RFC 6238 §B vector: SHA-512, t=1234567890, 8 digits.",
      "input": {
        "secret_ascii": "1234567890123456789012345678901234567890123456789012345678901234",
        "timestamp": 1234567890,
        "digits": 8,
        "algorithm": "sha512"
      },
      "expected": { "result": "93441116" }
    },
    {
      "id": "totp.sha512.t-2000000000",
      "description": "RFC 6238 §B vector: SHA-512, t=2000000000, 8 digits.",
      "input": {
        "secret_ascii": "1234567890123456789012345678901234567890123456789012345678901234",
        "timestamp": 2000000000,
